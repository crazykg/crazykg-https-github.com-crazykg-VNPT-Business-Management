APP_NAME=Laravel
# Safe defaults for staging/production.
# Local development can override in private `.env` (do not commit runtime secrets).
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vnpt_business_db
DB_USERNAME=app_rw
DB_PASSWORD=change_me
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_0900_ai_ci
DB_STRICT=true
DB_ENGINE=InnoDB
DB_EMULATE_PREPARES=false
DB_STRINGIFY_FETCHES=false
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_EXPIRATION=60

VNPT_AUTH_COOKIE_NAME=vnpt_business_auth_token
VNPT_AUTH_COOKIE_MINUTES=60
VNPT_AUTH_ACCESS_COOKIE_NAME=vnpt_business_auth_token
VNPT_AUTH_ACCESS_COOKIE_MINUTES=60
VNPT_AUTH_REFRESH_COOKIE_NAME=vnpt_business_refresh_token
VNPT_AUTH_REFRESH_COOKIE_MINUTES=10080
VNPT_AUTH_COOKIE_PATH=/
VNPT_AUTH_COOKIE_DOMAIN=null
VNPT_AUTH_COOKIE_SECURE=true
VNPT_AUTH_COOKIE_SAME_SITE=strict

# CORS — danh sach origins duoc phep, cach nhau bang dau phay.
# Local development co the override trong `.env` rieng neu can them origins khac.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5174

API_MAX_BODY_KB=25600

BROADCAST_CONNECTION=log
VNPT_REALTIME_ENABLED=false
VNPT_REALTIME_DASHBOARD_CHANNEL=v5.dashboards
REVERB_APP_ID=100001
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=http://127.0.0.1:5174
FILESYSTEM_DISK=local
# Staging/production: use Redis queue for async exports.
# Local can override to `database` if Redis is unavailable.
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_IMPERSONATE_USER=
GOOGLE_DRIVE_FILE_PREFIX=VNPT

VITE_APP_NAME="${APP_NAME}"
